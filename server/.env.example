PORT=8080
POSTGRES_URL=postgres://admin:admin@localhost:5432/notification?sslmode=disable
RABBITMQ_URL=amqp://admin:admin@localhost:5672/
REDIS_URL=redis://localhost:6379/0
RABBITMQ_FANOUT_QUEUE=notifications.fanout
RABBITMQ_DELIVERY_QUEUE=notifications.delivery
RABBITMQ_DELIVERY_RETRY_PREFIX=notifications.delivery.retry
FANOUT_WORKER_COUNT=8
DELIVERY_WORKER_COUNT=128
RABBITMQ_FANOUT_PREFETCH_COUNT=16
RABBITMQ_DELIVERY_PREFETCH_COUNT=256
FANOUT_BATCH_SIZE=5000
DELIVERY_BATCH_SIZE=500
DELIVERY_ATTEMPTS_PER_BATCH=32
RATE_LIMIT_PER_MINUTE=120
REQUEST_TIMEOUT_SECONDS=15
MAX_RETRIES=3
